GEMINI_API_KEY=your-api-key-here

# Gmail Integration (optional)
# Download credentials.json from Google Cloud Console — see README for setup steps
GOOGLE_CREDENTIALS_PATH=credentials.json

# Telegram Bot (optional) — get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Scheduler timezone (optional, default: UTC)
# Examples: Asia/Kolkata, America/New_York, Europe/London
DEFAULT_TIMEZONE=UTC
